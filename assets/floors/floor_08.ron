    EntityDef(
      pos: (3.5, 5.5),
      kind: Interactable(
        prompt: "Release containment subjects",
        require: None,
        action: MoralChoice(flag: "released_f8_subjects", release_subjects: true, score: 1),
        texture_id: None,
        scale: 0.5,
      ),
    ),
    // --- Puzzle 2–3: biometric door (collected_limb >= 3) ---
    EntityDef(
      pos: (12.5, 5.5),
      kind: Interactable(
        prompt: "Biometric door (requires 3 limbs)",
        require: Some("collected_limb >= 3"),
        action: OpenDoor(cell:(12,4), flag:Some("exec_open")),
        texture_id: None,
        scale: 0.5,
      ),
    ),
    // --- Puzzle 4: elevator (flag from biometric) ---
    EntityDef(
      pos: (12.5, 15.8),
      kind: Interactable(
        prompt: "Call elevator",
        require: Some("exec_open"),
        action: CallElevator,
        texture_id: None,
        scale: 0.6,
      ),
    ),
